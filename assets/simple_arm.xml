<mujoco model="simple_controller_arm">
  <compiler angle="radian" autolimits="true"/>
  <option timestep="0.002" gravity="0 0 -9.81" integrator="RK4"/>
  <visual>
    <global offwidth="1280" offheight="960"/>
  </visual>

  <default>
    <geom rgba="0.45 0.48 0.52 1" density="600" friction="0.8 0.1 0.1"/>
    <joint damping="1.5" armature="0.02" limited="true"/>
    <position kp="120" kv="18"/>
  </default>

  <asset>
    <material name="base_mat" rgba="0.18 0.2 0.22 1"/>
    <material name="arm_mat" rgba="0.35 0.52 0.66 1"/>
    <material name="wrist_mat" rgba="0.70 0.63 0.45 1"/>
    <material name="gripper_mat" rgba="0.12 0.12 0.12 1"/>
    <texture name="grid" type="2d" builtin="checker" rgb1="0.25 0.25 0.25" rgb2="0.32 0.32 0.32" width="256" height="256"/>
    <material name="floor_mat" texture="grid" texrepeat="6 6" reflectance="0.1"/>
  </asset>

  <worldbody>
    <light pos="0 -1 2" dir="0 1 -2"/>
    <camera name="overview" pos="0.78 -0.92 0.72" xyaxes="0.78 0.63 0 -0.29 0.36 0.89"/>
    <geom name="floor" type="plane" size="1.5 1.5 0.03" material="floor_mat"/>
    <body name="base" pos="0 0 0.06">
      <geom name="base_geom" type="cylinder" size="0.08 0.05" material="base_mat"/>

      <body name="shoulder_yaw" pos="0 0 0.06">
        <joint name="joint_1_yaw" type="hinge" axis="0 0 1" range="-2.8 2.8"/>
        <geom type="sphere" size="0.055" material="base_mat"/>

        <body name="shoulder_pitch" pos="0 0 0.04">
          <joint name="joint_2_shoulder" type="hinge" axis="0 1 0" range="-1.6 1.4"/>
          <geom type="capsule" fromto="0 0 0 0.24 0 0" size="0.035" material="arm_mat"/>

          <body name="elbow_pitch" pos="0.24 0 0">
            <joint name="joint_3_elbow" type="hinge" axis="0 1 0" range="-2.4 0.2"/>
            <geom type="capsule" fromto="0 0 0 0.22 0 0" size="0.03" material="arm_mat"/>

            <body name="wrist_yaw" pos="0.22 0 0">
              <joint name="joint_4_wrist_yaw" type="hinge" axis="0 0 1" range="-2.8 2.8"/>
              <geom type="sphere" size="0.035" material="wrist_mat"/>

              <body name="wrist_pitch" pos="0.04 0 0">
                <joint name="joint_5_wrist_pitch" type="hinge" axis="0 1 0" range="-1.8 1.8"/>
                <geom type="capsule" fromto="0 0 0 0.09 0 0" size="0.022" material="wrist_mat"/>

                <body name="wrist_roll" pos="0.09 0 0">
                  <joint name="joint_6_wrist_roll" type="hinge" axis="1 0 0" range="-3.14 3.14"/>
                  <geom type="capsule" fromto="0 0 0 0.05 0 0" size="0.018" material="wrist_mat"/>

                  <body name="gripper" pos="0.06 0 0">
                    <site name="ee_site" pos="0 0 0" size="0.012" rgba="1 0.2 0.1 1"/>
                    <geom name="palm" type="box" pos="0 0 0" size="0.015 0.04 0.018" material="gripper_mat"/>

                    <body name="left_finger" pos="0 0.035 0">
                      <joint name="left_gripper" type="slide" axis="0 1 0" range="0 0.025" damping="0.4"/>
                      <geom type="box" pos="0.035 0 0" size="0.035 0.006 0.012" material="gripper_mat"/>
                    </body>

                    <body name="right_finger" pos="0 -0.035 0">
                      <joint name="right_gripper" type="slide" axis="0 -1 0" range="0 0.025" damping="0.4"/>
                      <geom type="box" pos="0.035 0 0" size="0.035 0.006 0.012" material="gripper_mat"/>
                    </body>
                  </body>
                </body>
              </body>
            </body>
          </body>
        </body>
      </body>
    </body>

    <body name="target_marker" mocap="true" pos="0.35 0 0.22">
      <geom name="target_marker_geom" type="sphere" size="0.018" rgba="0.1 0.8 0.25 0.45" contype="0" conaffinity="0"/>
    </body>
  </worldbody>

  <actuator>
    <position name="act_joint_1" joint="joint_1_yaw" ctrlrange="-2.8 2.8"/>
    <position name="act_joint_2" joint="joint_2_shoulder" ctrlrange="-1.6 1.4"/>
    <position name="act_joint_3" joint="joint_3_elbow" ctrlrange="-2.4 0.2"/>
    <position name="act_joint_4" joint="joint_4_wrist_yaw" ctrlrange="-2.8 2.8"/>
    <position name="act_joint_5" joint="joint_5_wrist_pitch" ctrlrange="-1.8 1.8"/>
    <position name="act_joint_6" joint="joint_6_wrist_roll" ctrlrange="-3.14 3.14"/>
    <position name="act_left_gripper" joint="left_gripper" ctrlrange="0 0.025" kp="80" kv="8"/>
    <position name="act_right_gripper" joint="right_gripper" ctrlrange="0 0.025" kp="80" kv="8"/>
  </actuator>
</mujoco>
